# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Supabase Storage (para fotos en producción)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Next.js ──────────────────────────────────────────────────────────────────
# URL base de la API (vacío = mismo dominio, útil para Vercel)
NEXT_PUBLIC_API_URL=
